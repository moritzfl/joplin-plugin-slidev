{
	"manifest_version": 1,
	"id": "de.moritzf.slidev-integration",
	"app_min_version": "3.5.11",
	"version": "0.3.1",
	"name": "Slidev Integration",
	"description": "Turn Joplin notes into Slidev presentations!",
	"author": "moritz",
	"homepage_url": "https://github.com/moritzfl/joplin-plugin-slidev",
	"repository_url": "https://github.com/moritzfl/joplin-plugin-slidev",
	"keywords": ["slides", "slidev", "presentation", "slidedeck"],
	"categories": ["integrations"],
	"screenshots": [
		{
			"src": "images/screenshot-running-presentation.png",
			"label": "Screenshot: A Slidev presentation running from a Joplin note."
		},
		{
			"src": "images/screenshot-marketplace.png",
			"label": "Screenshot: The Slidev theme and addon marketplace inside Joplin."
		}
	],
	"icons": {
		"16": "icons/icon-16.png",
		"32": "icons/icon-32.png",
		"48": "icons/icon-48.png",
		"128": "icons/icon-128.png"
	}
}
